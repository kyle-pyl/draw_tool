    {
      "id": "tp_zones",
      "name": "Network Zones",
      "order": 1,
      "visible": true,
      "locked": false,
      "defaultStyle": {
        "fill": "none",
        "stroke": "#90A4AE",
        "strokeWidth": 2,
        "opacity": 1,
        "strokeDasharray": "6,3"
      }
    },
    {
      "id": "tp_devices",
      "name": "Network Devices",
      "order": 2,
      "visible": true,
      "locked": false,
      "defaultStyle": {
        "fill": "#E3F2FD",
        "stroke": "#1565C0",
        "strokeWidth": 2,
        "opacity": 1
      }
    },
    {
      "id": "tp_labels",
      "name": "Device Labels",
      "order": 3,
      "visible": true,
      "locked": false,
      "defaultStyle": {
        "fill": "#263238",
        "stroke": "none",
        "strokeWidth": 0,
        "opacity": 1,
        "fontSize": 11,
        "fontFamily": "Arial",
        "fontWeight": "bold"
