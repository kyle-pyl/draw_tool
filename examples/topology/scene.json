{
  "schemaVersion": "1.0.0",
  "project": {
    "name": "Network Topology Example",
    "author": "OpenCode",
    "description": "A three-tier enterprise network topology showing core, distribution, and access layers with DMZ and server farm."
  },
  "canvas": {
    "units": "px",
    "background": "#F4F6F8",
    "defaultFont": "Arial",
    "gridSize": 0,
    "snapToGrid": false
  },
  "rules": {
    "maxLayerCount": 10,
    "collisionStrategy": "bbox",
    "hiddenElementsCollide": true,
    "lockedElementsCollide": true,
    "connectorsExempt": true
  },
