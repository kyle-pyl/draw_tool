{
  "name": "draw-tool",
  "private": true,
  "version": "0.1.0",
  "description": "Agent-friendly drawing tool for paper figures, flowcharts, architecture diagrams, RTL module diagrams, mind maps and network topology",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lite": "VITE_BUNDLE=lite vite build",
    "build:full": "VITE_BUNDLE=full vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "api:validate": "node scripts/api-registry-helper.mjs validate",
    "api:list": "node scripts/api-registry-helper.mjs list",
    "api:next": "node scripts/api-registry-helper.mjs next"
  },
  "dependencies": {
    "@types/papaparse": "^5.5.2",
    "fflate": "^0.8.3",
    "papaparse": "^5.5.3",
    "polygon-clipping": "^0.15.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.45.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "jsdom": "^24.1.3",
    "prettier": "^3.3.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10",
    "vitest": "^1.6.0"
  }
}
